<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Housekeeping - Panel Supervisor</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            hotel: {
              dark: '#0F2B48',
              primary: '#2D5B7C',
              light: '#E8F0F5',
              accent: '#F2994A',
              success: '#27AE60',
              danger: '#E74C3C',
              neutral: '#F8FAFC'
            }
          },
          fontFamily: {
            sans: ['Segoe UI', 'Roboto', 'Arial', 'sans-serif']
          }
        }
      }
    }
  </script>
  <style type="text/tailwindcss">
    @layer utilities {
      .content-auto {
        content-visibility: auto;
      }
      .table-cell {
        @apply border border-gray-300 p-2 text-center align-middle;
      }
      .table-header {
        @apply border border-gray-300 p-2 bg-hotel-light font-semibold text-hotel-dark;
      }
    }
  </style>
</head>
<body class="bg-hotel-neutral min-h-screen">
  <div class="container mx-auto px-3 py-4 max-w-7xl">

    <!-- Header Selamat Datang -->
    <div class="bg-white rounded-lg shadow-md mb-5 overflow-hidden">
      <div class="bg-hotel-dark text-white px-5 py-4 flex flex-wrap justify-between items-center gap-3">
        <div class="flex items-center gap-3">
          <i class="fa fa-user-circle-o text-2xl"></i>
          <div>
            <h1 class="text-lg font-bold">Panel Supervisor Housekeeping</h1>
            <p class="text-sm opacity-90">Selamat datang, <strong><%= user.nama %></strong></p>
          </div>
        </div>
        <div class="flex gap-3">
          <a href="/unduh" class="bg-hotel-accent hover:bg-amber-500 text-white px-4 py-2 rounded-md text-sm font-medium transition flex items-center gap-1">
            <i class="fa fa-download"></i> Unduh Laporan
          </a>
          <a href="/logout" class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-md text-sm font-medium transition flex items-center gap-1">
            <i class="fa fa-sign-out"></i> Keluar
          </a>
        </div>
      </div>
    </div>

    <!-- Form Tambah Tugas -->
    <div class="bg-white rounded-lg shadow-md mb-5 overflow-hidden">
      <div class="bg-hotel-primary text-white px-5 py-3">
        <h2 class="text-base font-semibold flex items-center gap-2">
          <i class="fa fa-list-alt"></i> Berikan Tugas Kebersihan
        </h2>
      </div>
      <div class="p-5">
        <form method="POST" action="/tambah-tugas" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 items-end">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Tanggal</label>
            <input type="date" name="tanggal" value="<%= new Date().toISOString().split('T')[0] %>" required
              class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-1 focus:ring-hotel-primary">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Nomor Kamar</label>
            <input type="text" name="kamar" placeholder="Contoh: 301" required
              class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-1 focus:ring-hotel-primary">
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Room Attendant</label>
            <select name="petugas" required
              class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-1 focus:ring-hotel-primary">
              <option value="Aslan">Aslan</option>
              <option value="Bila">Bila</option>
              <option value="Fika">Fika</option>
              <option value="Indah">Indah</option>
              <option value="Apri">Apri</option>
              <option value="Revan">Revan</option>
              <option value="Alwi">Alwi</option>
              <option value="Ajril">Ajril</option>
            </select>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Status Awal Kamar</label>
            <select name="status_awal" required
              class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-1 focus:ring-hotel-primary">
              <option value="VC">VC - Vacant Clean</option>
              <option value="VD">VD - Vacant Dirty</option>
              <option value="OC">OC - Occupied Clean</option>
              <option value="OD">OD - Occupied Dirty</option>
              <option value="OOO">OOO - Out Of Order</option>
            </select>
          </div>
          <div>
            <button type="submit"
              class="w-full bg-hotel-primary hover:bg-hotel-dark text-white px-4 py-2 rounded-md font-medium transition flex items-center justify-center gap-2">
              <i class="fa fa-plus"></i> Tambah Tugas
            </button>
          </div>
        </form>
      </div>
    </div>

    <!-- Daftar Tugas -->
    <div class="bg-white rounded-lg shadow-md overflow-hidden">
      <div class="bg-hotel-primary text-white px-5 py-3">
        <h2 class="text-base font-semibold flex items-center gap-2">
          <i class="fa fa-clipboard"></i> Daftar Tugas Hari Ini
        </h2>
      </div>
      <div class="p-5 overflow-x-auto">
        <% if (tugas && tugas.length > 0) { %>
        <table class="w-full border-collapse">
          <thead>
            <tr>
              <th class="table-header">No</th>
              <th class="table-header">Tanggal</th>
              <th class="table-header">No Kamar</th>
              <th class="table-header">Room Attendant</th>
              <th class="table-header">Status Awal</th>
              <th class="table-header">Status Pengerjaan</th>
            </tr>
          </thead>
          <tbody>
            <% tugas.forEach((item, index) => { %>
            <tr class="hover:bg-gray-50">
              <td class="table-cell"><%= index + 1 %></td>
              <td class="table-cell"><%= item.tanggal %></td>
              <td class="table-cell font-medium"><%= item.kamar %></td>
              <td class="table-cell"><%= item.petugas %></td>
              <td class="table-cell"><span class="px-2 py-1 rounded text-xs font-medium bg-gray-100"><%= item.status_awal %></span></td>
              <td class="table-cell">
                <% if (item.selesai) { %>
                  <span class="text-hotel-success font-medium flex items-center justify-center gap-1">
                    <i class="fa fa-check-circle"></i> Selesai
                  </span>
                <% } else { %>
                  <span class="text-orange-500 font-medium flex items-center justify-center gap-1">
                    <i class="fa fa-clock-o"></i> Belum Selesai
                  </span>
                <% } %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
        <% } else { %>
        <div class="text-center py-10 text-gray-500">
          <i class="fa fa-clipboard text-4xl mb-3 opacity-40"></i>
          <p>Belum ada tugas yang ditambahkan untuk hari ini</p>
        </div>
        <% } %>
      </div>
    </div>

  </div>
</body>
</html>
