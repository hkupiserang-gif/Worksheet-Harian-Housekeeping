<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Supervisor</title>
  <style>
    * {margin:0; padding:0; box-sizing:border-box; font-family:Arial, sans-serif;}
    body {background:#f8fafc;}
    header {background:#004b8d; color:white; padding:12px 24px; display:flex; justify-content:space-between; align-items:center;}
    .container {max-width:1200px; margin:24px auto; padding:0 16px;}
    .pesan {padding:10px; border-radius:4px; margin-bottom:16px; font-size:14px;}
    .pesan.error {background:#ffe9e9; color:#b02020; border:1px solid #f8cccc;}
    .pesan.sukses {background:#e6f9ed; color:#157c38; border:1px solid #c8f0d6;}
    .card {background:white; border-radius:6px; padding:16px; box-shadow:0 1px 3px #0002; margin-bottom:20px;}
    h3 {margin-bottom:12px; color:#222;}
    form {display:grid; grid-template-columns:repeat(auto-fit, minmax(150px, 1fr)); gap:12px; align-items:end;}
    input, select {padding:8px; border:1px solid #ddd; border-radius:4px; font-size:14px;}
    button {padding:9px 12px; background:#004b8d; color:white; border:none; border-radius:4px; cursor:pointer; font-size:14px;}
    button:hover {background:#003a6e;}
    table {width:100%; border-collapse:collapse; margin-top:12px;}
    th, td {padding:10px; text-align:left; border-bottom:1px solid #eee; font-size:14px;}
    th {background:#f2f5f9; font-weight:600;}
    a {color:white; text-decoration:none;}
  </style>
</head>
<body>
  <header>
    <h2>Panel Supervisor</h2>
    <div>
      Halo, <%= user.nama %> | <a href="/logout">Keluar</a>
    </div>
  </header>

  <div class="container">
    <% if (pesan) { %>
      <div class="pesan <%= pesan.tipe %>"><%= pesan.teks %></div>
    <% } %>

    <div class="card">
      <h3>Buat Tugas Kebersihan</h3>
      <form action="/tambah-tugas" method="POST">
        <input type="date" name="tanggal" value="<%= tanggal %>" required>
        <select name="petugas" required>
          <option value="">-- Pilih Petugas --</option>
          <% daftarRA.forEach(ra => { %>
            <option value="<%= ra.nama %>"><%= ra.nama %></option>
          <% }) %>
        </select>
        <select name="kamar" required>
          <option value="">-- Pilih Kamar --</option>
          <% daftarKamar.forEach(k => { %>
            <option value="<%= k.nomor_kamar %>"><%= k.nomor_kamar %> | <%= k.lantai %> | <%= k.tipe_kamar %></option>
          <% }) %>
        </select>
        <select name="status_awal" required>
          <option value="">-- Status --</option>
          <option value="VD">VD</option>
          <option value="VC">VC</option>
          <option value="VCU">VCU</option>
          <option value="OC">OC</option>
          <option value="OD">OD</option>
        </select>
        <button type="submit">Simpan Tugas</button>
      </form>
    </div>

    <div class="card">
      <h3>Daftar Tugas Hari Ini (<%= tanggal %>)</h3>
      <table>
        <thead>
          <tr>
            <th>No. Kamar</th>
            <th>Lantai</th>
            <th>Petugas</th>
            <th>Status Awal</th>
            <th>Selesai</th>
          </tr>
        </thead>
        <tbody>
          <% if (daftarTugas.length > 0) { %>
            <% daftarTugas.forEach(t => { %>
              <tr>
                <td><strong><%= t.kamar %></strong></td>
                <td><%= t.lantai || '-' %></td>
                <td><%= t.petugas %></td>
                <td><%= t.status_awal %></td>
                <td><%= t.selesai ? '✅ Sudah' : '⏳ Belum' %></td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr><td colspan="5" style="text-align:center; color:#777; padding:20px;">Belum ada tugas dibuat hari ini</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
