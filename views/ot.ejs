    function updateLaundryPrice(rowId) {
      const itemSelect = document.querySelector(`.laundry-item[data-row="${rowId}"]`);
      const priceDisplay = document.querySelector(`.laundry-price[data-row="${rowId}"]`);
      const priceInput = document.querySelector(`.laundry-price-input[data-row="${rowId}"]`);
      const unitInput = document.querySelector(`.laundry-unit-input[data-row="${rowId}"]`);

      const selected = itemSelect.options[itemSelect.selectedIndex];
      const price = selected ? parseInt(selected.dataset.price || 0) : 0;
      const unit = selected ? selected.dataset.unit || 'Pcs' : 'Pcs';

      priceDisplay.textContent = price > 0 ? formatRupiah(price) : '-';
      priceInput.value = price;
      unitInput.value = unit;
      calculateLaundryTotal();
    }

    function calculateLaundryTotal() {
      let total = 0;
      document.querySelectorAll('.item-row').forEach(row => {
        if (row.id && row.id.startsWith('laundry-row-')) {
          const qtyInput = row.querySelector('.laundry-qty');
          const priceInput = row.querySelector('.laundry-price-input');
          const qty = parseInt(qtyInput?.value || 0);
          const price = parseInt(priceInput?.value || 0);
          total += qty * price;
