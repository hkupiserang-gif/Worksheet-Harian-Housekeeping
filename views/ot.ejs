      priceInput.value = price;
      unitInput.value = unit;
      calculateStoreTotal();
    }

    function calculateStoreTotal() {
      let total = 0;
      document.querySelectorAll('.item-row').forEach(row => {
        if (row.id && row.id.startsWith('store-row-')) {
          const qtyInput = row.querySelector('.store-qty');
          const priceInput = row.querySelector('.store-price-input');
          const subtotalDisplay = row.querySelector('.store-subtotal');
          const qty = parseInt(qtyInput?.value || 0);
          const price = parseInt(priceInput?.value || 0);
          const subtotal = qty * price;
          if (subtotalDisplay) subtotalDisplay.textContent = formatRupiah(subtotal);
          total += subtotal;
        }
      });
      document.getElementById('storeGrandTotal').textContent = formatRupiah(total);
    }

    // =====================================================
    // PWA & MOBILE FEATURES
    // =====================================================
    function scrollToSection(id) {
      document.getElementById(id).scrollIntoView({ behavior: 'smooth' });
      // Update active state
      document.querySelectorAll('.bottom-nav-item').forEach(el => el.classList.remove('active'));
      event.currentTarget.classList.add('active');
    }

    // Pull to refresh
    let touchStartY = 0;
    let touchEndY = 0;
    const ptrIndicator = document.getElementById('ptrIndicator');

    document.addEventListener('touchstart', e => {
      touchStartY = e.changedTouches[0].screenY;
    }, {passive: true});

    document.addEventListener('touchend', e => {
      touchEndY = e.changedTouches[0].screenY;
      if (touchEndY > touchStartY + 150 && window.scrollY === 0) {
        ptrIndicator.classList.add('show');
        setTimeout(() => {
          location.reload();
        }, 500);
      }
    }, {passive: true});

    // PWA Install Prompt
    let deferredPrompt;
    const installPrompt = document.getElementById('installPrompt');

    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault();
      deferredPrompt = e;
      installPrompt.classList.add('show');
    });

    function installApp() {
      if (deferredPrompt) {
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then((choiceResult) => {
          if (choiceResult.outcome === 'accepted') {
            console.log('User installed the app');
          }
          deferredPrompt = null;
          installPrompt.classList.remove('show');
        });
      }
    }

    // Service Worker Registration
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js').then(() => {
        console.log('Service Worker registered');
      }).catch(err => {
        console.log('SW registration failed:', err);
      });
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', function() {
      addLaundryRow();
      addFnbRow();
      addStoreRow();
    });

    // Live clock
    setInterval(() => {
      const jakartaTime = new Date(new Date().toLocaleString('en-US', { timeZone: 'Asia/Jakarta' }));
      const jam = String(jakartaTime.getHours()).padStart(2, '0');
      const menit = String(jakartaTime.getMinutes()).padStart(2, '0');
      const detik = String(jakartaTime.getSeconds()).padStart(2, '0');
      const el = document.getElementById('jamSekarang');
      if (el) el.textContent = `${jam}:${menit}:${detik}`;
    }, 1000);
  </script>
</body>
</html>
