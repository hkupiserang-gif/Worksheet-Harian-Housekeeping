      let categoryOptions = '<option value="">-- Pilih Kategori --</option>';
      for (let cat in laundryItems) {
        categoryOptions += `<option value="${cat}">${cat}</option>`;
      }

      row.innerHTML = '<div>' +
          '<select class="laundry-cat" data-row="' + laundryRowCount + '" onchange="updateLaundryItems(' + laundryRowCount + ')" required>' +
            categoryOptions +
          '</select>' +
        '</div>' +
        '<div>' +
          '<select class="laundry-item" name="items[' + laundryRowCount + '][nama]" data-row="' + laundryRowCount + '" onchange="updateLaundryPrice(' + laundryRowCount + ')" required>' +
            '<option value="">-- Pilih Item --</option>' +
          '</select>' +
        '</div>' +
        '<div>' +
          '<input type="number" class="laundry-qty" name="items[' + laundryRowCount + '][qty]" data-row="' + laundryRowCount + '" placeholder="QTY" min="0" value="0" oninput="calculateLaundryTotal()" required>' +
        '</div>' +
        '<div class="price-display">' +
          '<span class="laundry-price" data-row="' + laundryRowCount + '">Rp 0</span>' +
          '<input type="hidden" class="laundry-price-input" name="items[' + laundryRowCount + '][harga]" data-row="' + laundryRowCount + '">' +
