      <table>
        <thead>
          <tr>
            <th>No</th>
            <th>Petugas</th>
            <th>Kategori</th>
            <th>Barang</th>
            <th>Unit</th>
            <th>QTY</th>
            <th>Harga</th>
            <th>Total</th>
            <th>Status</th>
            <th>Waktu</th>
            <th>Aksi</th>
          </tr>
        </thead>
        <tbody>
          <% daftarStore.forEach((item, index) => { %>
          <tr>
            <td><%= index + 1 %></td>
            <td><strong><%= item.petugas || '-' %></strong></td>
            <td><span style="background:#e0e7ff; padding:3px 8px; border-radius:4px; font-size:11px;"><%= item.kategori || '-' %></span></td>
            <td><strong><%= item.nama_barang || '-' %></strong></td>
            <td><%= item.unit || '-' %></td>
            <td><%= item.jumlah || 0 %></td>
            <td>Rp <%= (item.harga || 0).toLocaleString('id-ID') %></td>
            <td><strong>Rp <%= (item.total_harga || 0).toLocaleString('id-ID') %></strong></td>
            <td>
              <span class="status-badge status-<%= item.status.toLowerCase() %>">
                <%= item.status %>
              </span>
            </td>
            <td><%= item.waktu_input || '-' %></td>
            <td class="aksi">
              <% if (item.status === 'Pending') { %>
              <form action="/ubah-status-store" method="POST" style="display:inline;">
                <input type="hidden" name="id" value="<%= item.id %>">
                <input type="hidden" name="status" value="Approved">
                <button type="submit" class="btn btn-hijau">Approve</button>
              </form>
              <% } else if (item.status === 'Approved') { %>
