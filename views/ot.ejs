    function updateLaundryItems(rowId) {
      const catSelect = document.querySelector(`.laundry-cat[data-row="${rowId}"]`);
      const itemSelect = document.querySelector(`.laundry-item[data-row="${rowId}"]`);
      const category = catSelect.value;

      itemSelect.innerHTML = '<option value="">-- Pilih Item --</option>';
      if (category && laundryItems[category]) {
        laundryItems[category].forEach(item => {
          const priceText = item.price > 0 ? `Rp ${item.price.toLocaleString('id-ID')}` : 'Harga belum tersedia';
