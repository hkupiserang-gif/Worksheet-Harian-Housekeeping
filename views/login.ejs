<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Login - Horison Hotel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #0054A6; height: 100vh; display: flex; align-items: center; justify-content: center; }
    .login-box { background: white; padding: 30px; border-radius: 8px; width: 100%; max-width: 380px; box-shadow: 0 0 15px rgba(0,0,0,0.2); }
  </style>
</head>
<body>
  <div class="login-box">
    <h4 class="text-center mb-4">HORISON HOTEL</h4>
    <% if (pesan) { %>
      <div class="alert alert-danger"><%= pesan.teks %></div>
    <% } %>
    <form method="POST" action="/login">
      <div class="mb-3">
        <label class="form-label">Username</label>
        <input type="text" name="username" class="form-control" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" required>
      </div>
      <button type="submit" class="btn btn-primary w-100">Masuk</button>
    </form>
  </div>
</body>
</html>
