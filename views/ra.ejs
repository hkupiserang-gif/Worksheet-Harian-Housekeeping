<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Laporan Kamar</title>
  <style>
    body{font-family:Arial; max-width:700px; margin:20px auto; padding:0 15px; background:#f8f9fa;}
    .kotak{background:white; padding:15px; margin:15px 0; border-radius:6px; box-shadow:0 1px 3px #0002;}
    .kamar{padding:12px; border:1px solid #ddd; border-radius:4px; margin:8px 0;}
    .selesai{border-color:#27ae60; background:#f8fef9;}
    button{padding:7px 12px; border:none; border-radius:4px; cursor:pointer; font-weight:bold;}
    .hijau{background:#27ae60; color:white;}
    .kuning{background:#f39c12; color:white;}
  </style>
</head>
<body>
  <div class="kotak">
    <h3>Halo, <%= user.nama %></h3>
    <a href="/" style="color:#e74c3c; text-decoration:none; float:right;">Keluar</a>
  </div>

  <div class="kotak">
    <h4>Daftar Tugas Hari Ini</h4>
    <% if (tugas.length < 1) { %>
      <p style="text-align:center; color:#666;">Belum ada tugas</p>
    <% } else { %>
      <% tugas.forEach(t => { %>
        <div class="kamar <%= t.selesai ? 'selesai' : '' %>">
          <strong>Kamar <%= t.kamar %></strong><br>
          Status: <%= t.status_awal %><br>
          <% if (t.selesai) { %>✅ Selesai<% } else { %>
          <button class="kuning" onclick="buka('<%= t.kamar %>')">Isi Laporan</button>
          <% } %>
        </div>
      <% }) %>
    <% } %>
  </div>

  <div class="kotak" id="form" style="display:none;">
    <h4>Isi Laporan</h4>
    <form method="POST" action="/simpan">
      <input type="hidden" name="tanggal" value="<%= new Date().toISOString().split('T')[0] %>">
      <input type="hidden" name="kamar" id="kamar">
      <label>Status</label>
      <select name="status" required style="width:100%; padding:8px; margin:6px 0;">
        <option value="VC">VC - Bersih Kosong</option>
        <option value="VD">VD - Kotor Kosong</option>
        <option value="OC">OC - Bersih Terisi</option>
        <option value="OD">OD - Kotor Terisi</option>
      </select>
      <label>Jam Masuk</label>
      <input type="time" name="masuk" required>
      <label>Jam Keluar</label>
      <input type="time" name="keluar" required>
      <label>Keterangan</label>
      <input type="text" name="keterangan" placeholder="Contoh: keran bocor">
      <div style="margin-top:10px;">
        <button type="submit" class="hijau">Simpan</button>
        <button type="button" onclick="tutup()" style="background:#999; color:white;">Batal</button>
      </div>
    </form>
  </div>

  <script>
    function buka(kamar) {
      document.getElementById('kamar').value = kamar;
      document.getElementById('form').style.display = 'block';
    }
    function tutup() {
      document.getElementById('form').style.display = 'none';
    }
  </script>
</body>
</html>
