<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Roomboy Control Sheet</title>
  <style>
    * { margin:0; padding:0; box-sizing:border-box; font-family:Arial; font-size:12px; }
    body { background:#f8f9fa; padding:15px; }
    .card { background:#fff; border:1px solid #333; margin-bottom:15px; }
    .header { padding:8px; border-bottom:1px solid #333; font-weight:bold; text-align:center; font-size:14px; }
    .info-bar { display:grid; grid-template-columns: repeat(4, 1fr); padding:8px; gap:8px; border-bottom:1px solid #333; }
    table { width:100%; border-collapse: collapse; }
    th, td { border:1px solid #333; padding:6px; text-align:center; vertical-align:middle; }
    th { background:#eee; font-weight:bold; }
    input[type="text"], input[type="time"], select { width:100%; padding:4px; border:1px solid #999; }
    input[type="checkbox"] { width:18px; height:18px; }
    .btn { padding:8px 15px; border:none; border-radius:4px; cursor:pointer; font-weight:bold; margin:5px; }
    .btn-hijau { background:#27ae60; color:white; }
    .btn-abu { background:#95a5a6; color:white; }
  </style>
</head>
<body>

<div class="card">
  <div class="header">ROOMBOY CONTROL SHEET</div>
  <div class="info-bar">
    <div>NAME: <input type="text" name="nama_petugas" value="<%= user.nama %>" readonly></div>
    <div>DATE: <input type="date" name="tanggal" value="<%= new Date().toISOString().split('T')[0] %>" readonly></div>
    <div>SHIFT: <select name="shift"><option>Morning</option><option>Afternoon</option><option>Night</option></select></div>
    <div>FLOOR/SECTION: <input type="text" name="lantai_bagian" placeholder="Contoh: Lantai 3"></div>
  </div>

  <form method="POST" action="/simpan-laporan">
    <input type="hidden" name="kamar" id="kamarInput">

    <table>
      <thead>
        <tr>
          <th rowspan="2">NO</th>
          <th rowspan="2">NO OF ROOM</th>
          <th colspan="3">ROOM STATUS</th>
          <th colspan="2">TIME</th>
          <th colspan="8">SHEET</th>
          <th colspan="4">DUVET COVER</th>
          <th colspan="8">LINEN</th>
          <th colspan="7">BATH ROOM</th>
          <th colspan="6">BED ROOM</th>
          <th colspan="5">CONDIMEN</th>
          <th rowspan="2">REMARKS</th>
        </tr>
        <tr>
          <th>FO</th><th>HK</th><th>OUT</th>
          <th>IN</th><th>OUT</th>
          <th>DOUBLE IN</th><th>DOUBLE OUT</th><th>SINGLE IN</th><th>SINGLE OUT</th>
          <th>IN</th><th>OUT</th><th>SINGLE IN</th><th>SINGLE OUT</th>
          <th>BATH TOWEL IN</th><th>BATH TOWEL OUT</th><th>HAND TOWEL IN</th><th>HAND TOWEL OUT</th><th>BATH MAT IN</th><th>BATH MAT OUT</th><th>PILLOW CASE IN</th><th>PILLOW CASE OUT</th>
          <th>TISSUE ROLL</th><th>HAND SOAP</th><th>SHAMPOO</th><th>SHOWER GEL</th><th>TOOTH BRUSH</th><th>TOOTH PASTE</th><th>SHOWER CAP</th>
          <th>SLIPPER</th><th>LAUNDRY BAG</th><th>LAUNDRY LIST</th><th>MEMO PAD</th><th>PEN</th><th>PLASTIC BIN</th>
          <th>COFFEE</th><th>SUGAR</th><th>TEA</th><th>CREAMER</th><th>MINERAL WATER</th>
        </tr>
      </thead>
      <tbody>
        <% if (tugas.length > 0) { %>
          <% tugas.forEach((t, i) => { %>
          <tr>
            <td><%= i+1 %></td>
            <td><%= t.kamar %></td>
            <td><input type="checkbox" name="status_fo" value="FO"></td>
            <td><input type="checkbox" name="status_hk" value="HK"></td>
            <td><input type="checkbox" name="status_out" value="OUT"></td>
            <td><input type="time" name="waktu_masuk" required></td>
            <td><input type="time" name="waktu_keluar" required></td>

            <!-- Sheet -->
            <td><input type="checkbox" name="sheet_double_in"></td>
            <td><input type="checkbox" name="sheet_double_out"></td>
            <td><input type="checkbox" name="sheet_single_in"></td>
            <td><input type="checkbox" name="sheet_single_out"></td>

            <!-- Duvet -->
            <td><input type="checkbox" name="duvet_cover_in"></td>
            <td><input type="checkbox" name="duvet_cover_out"></td>
            <td><input type="checkbox" name="duvet_single_in"></td>
            <td><input type="checkbox" name="duvet_single_out"></td>

            <!-- Linen -->
            <td><input type="checkbox" name="bath_towel_in"></td>
            <td><input type="checkbox" name="bath_towel_out"></td>
            <td><input type="checkbox" name="hand_towel_in"></td>
            <td><input type="checkbox" name="hand_towel_out"></td>
            <td><input type="checkbox" name="bath_mat_in"></td>
            <td><input type="checkbox" name="bath_mat_out"></td>
            <td><input type="checkbox" name="pillow_case_in"></td>
            <td><input type="checkbox" name="pillow_case_out"></td>

            <!-- Bathroom -->
            <td><input type="checkbox" name="tissue_roll"></td>
            <td><input type="checkbox" name="hand_soap"></td>
            <td><input type="checkbox" name="shampoo"></td>
            <td><input type="checkbox" name="shower_gel"></td>
            <td><input type="checkbox" name="tooth_brush"></td>
            <td><input type="checkbox" name="tooth_paste"></td>
            <td><input type="checkbox" name="shower_cap"></td>

            <!-- Bedroom -->
            <td><input type="checkbox" name="slipper"></td>
            <td><input type="checkbox" name="laundry_bag"></td>
            <td><input type="checkbox" name="laundry_list"></td>
            <td><input type="checkbox" name="memo_pad"></td>
            <td><input type="checkbox" name="pen"></td>
            <td><input type="checkbox" name="plastic_bin"></td>

            <!-- Condimen -->
            <td><input type="checkbox" name="coffee"></td>
            <td><input type="checkbox" name="sugar"></td>
            <td><input type="checkbox" name="tea"></td>
            <td><input type="checkbox" name="creamer"></td>
            <td><input type="checkbox" name="mineral_water"></td>

            <td><input type="text" name="keterangan" placeholder="Catatan"></td>
          </tr>
          <% }) %>
        <% } else { %>
          <tr><td colspan="42">Belum ada tugas hari ini</td></tr>
        <% } %>
      </tbody>
    </table>

    <div style="text-align:center; margin-top:10px;">
      <button type="submit" class="btn btn-hijau">✅ Simpan Laporan</button>
      <a href="/" class="btn btn-abu">Keluar</a>
    </div>
  </form>
</div>

</body>
</html>
