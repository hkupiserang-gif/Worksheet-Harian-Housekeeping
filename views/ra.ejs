<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Petugas Kamar</title>
  <style>
    * {margin:0; padding:0; box-sizing:border-box; font-family:Arial, sans-serif;}
    body {background:#f8fafc;}
    header {background:#004b8d; color:white; padding:12px 24px; display:flex; justify-content:space-between; align-items:center;}
    .container {max-width:1000px; margin:24px auto; padding:0 16px;}
    .pesan {padding:10px; border-radius:4px; margin-bottom:16px; font-size:14px;}
    .pesan.error {background:#ffe9e9; color:#b02020; border:1px solid #f8cccc;}
    .pesan.sukses {background:#e6f9ed; color:#157c38; border:1px solid #c8f0d6;}
    .card {background:white; border-radius:6px; padding:16px; box-shadow:0 1px 3px #0002; margin-bottom:20px;}
    h3 {margin-bottom:12px; color:#222;}
    .form-group {margin-bottom:12px;}
    label {display:block; font-size:14px; margin-bottom:4px; color:#444;}
    input, textarea {width:100%; padding:8px; border:1px solid #ddd; border-radius:4px; font-size:14px;}
    textarea {resize:vertical; min-height:60px;}
    button {padding:9px 14px; background:#004b8d; color:white; border:none; border-radius:4px; cursor:pointer; font-size:14px;}
    button:hover {background:#003a6e;}
    a {color:white; text-decoration:none;}
  </style>
</head>
<body>
  <header>
    <h2>Panel Petugas Kamar</h2>
    <div>
      Halo, <%= user.nama %> | <a href="/logout">Keluar</a>
    </div>
  </header>

  <div class="container">
    <% if (pesan) { %>
      <div class="pesan <%= pesan.tipe %>"><%= pesan.teks %></div>
    <% } %>

    <% if (tugas.length === 0) { %>
      <div class="card">
        <p style="text-align:center; color:#777; padding:20px;">Belum ada tugas yang diberikan untuk hari ini</p>
      </div>
    <% } else { %>
      <% tugas.forEach(t => { %>
        <div class="card">
          <h3>Kamar <%= t.kamar %> • Status: <%= t.status_awal %></h3>
          <form action="/simpan-laporan" method="POST">
            <input type="hidden" name="tanggal" value="<%= t.tanggal %>">
            <input type="hidden" name="kamar" value="<%= t.kamar %>">

            <div class="form-group">
              <label>Waktu Mulai Bekerja:</label>
              <input type="time" name="waktu_masuk" value="<%= t.waktu_masuk || '' %>">
            </div>

            <div class="form-group">
              <label>Waktu Selesai Bekerja:</label>
              <input type="time" name="waktu_keluar" value="<%= t.waktu_keluar || '' %>">
            </div>

            <div class="form-group">
              <label>Keterangan / Catatan:</label>
              <textarea name="keterangan" placeholder="Contoh: ganti sprei, isi ulang perlengkapan..."><%= t.keterangan || '' %></textarea>
            </div>

            <button type="submit">Simpan Laporan</button>
          </form>
        </div>
      <% }) %>
    <% } %>
  </div>
</body>
</html>
