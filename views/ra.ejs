<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel Room Attendant - Horison Hotel</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <style>
    body { background-color: #f8f9fa; font-size: 0.9rem; }
    .header { background-color: #0054A6; color: white; padding: 15px 20px; border-radius: 0 0 8px 8px; margin-bottom: 20px; }
    .card { border-radius: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.08); margin-bottom: 20px; }
    .section-title { font-weight: bold; color: #0054A6; border-bottom: 1px solid #eee; padding-bottom: 5px; margin: 15px 0 10px; }
    .form-control-sm { text-align: center; }
  </style>
</head>
<body>
<div class="container-fluid px-3 py-2">
  <!-- Header -->
  <div class="header d-flex justify-content-between align-items-center">
    <div>
      <h4 class="mb-0">HORISON HOTEL</h4>
      <small>Panel Room Attendant</small>
    </div>
    <div class="text-end">
      <p class="mb-0">Petugas: <strong><%= user.nama %></strong></p>
      <p class="mb-0">Tanggal: <%= tanggal %> | Jam: <%= waktuSekarang %></p>
      <a href="/logout" class="btn btn-sm btn-light mt-1"><i class="bi bi-box-arrow-right me-1"></i>Keluar</a>
    </div>
  </div>

  <!-- Daftar Tugas -->
  <h5 class="mb-3">Daftar Kamar yang Harus Dibersihkan</h5>

  <% if (tugas.length === 0) { %>
    <div class="alert alert-info text-center py-5">
      <i class="bi bi-inbox fs-2 d-block mb-2"></i>
      Belum ada tugas yang diberikan hari ini.
    </div>
  <% } else { %>
    <% tugas.forEach((kamar, idx) => { %>
    <div class="card">
      <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Kamar <%= kamar.kamar %> | Status: <%= kamar.status_awal %></h5>
        <% if (kamar.waktu_keluar !== '-') { %>
          <span class="badge bg-success">Selesai</span>
        <% } else if (kamar.waktu_masuk !== '-') { %>
          <span class="badge bg-warning text-dark">Sedang Dikerjakan</span>
        <% } else { %>
          <form action="/mulai-kamar" method="POST" class="d-inline">
            <input type="hidden" name="tanggal" value="<%= tanggal %>">
            <input type="hidden" name="kamar" value="<%= kamar.kamar %>">
            <button type="submit" class="btn btn-sm btn-primary">Mulai Kerjakan</button>
          </form>
        <% } %>
      </div>

      <% if (kamar.waktu_masuk !== '-' && kamar.waktu_keluar === '-') { %>
      <div class="card-body">
        <form action="/selesai-kamar" method="POST">
          <input type="hidden" name="tanggal" value="<%= tanggal %>">
          <input type="hidden" name="kamar" value="<%= kamar.kamar %>">
          <input type="hidden" name="waktu_masuk" value="<%= kamar.waktu_masuk %>">

          <!-- LINEN -->
          <h6 class="section-title">LINEN</h6>
          <div class="row g-3">
            <div class="col-md-3">
              <label class="form-label">Sheet Double IN</label>
              <input type="number" name="sheet_double_in" class="form-control form-control-sm" min="0" value="<%= kamar.sheet_double_in %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Sheet Double OUT</label>
              <input type="number" name="sheet_double_out" class="form-control form-control-sm" min="0" value="<%= kamar.sheet_double_out %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Sheet Single IN</label>
              <input type="number" name="sheet_single_in" class="form-control form-control-sm" min="0" value="<%= kamar.sheet_single_in %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Sheet Single OUT</label>
              <input type="number" name="sheet_single_out" class="form-control form-control-sm" min="0" value="<%= kamar.sheet_single_out %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Duvet Cover IN</label>
              <input type="number" name="duvet_cover_in" class="form-control form-control-sm" min="0" value="<%= kamar.duvet_cover_in %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Duvet Cover OUT</label>
              <input type="number" name="duvet_cover_out" class="form-control form-control-sm" min="0" value="<%= kamar.duvet_cover_out %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Duvet Single IN</label>
              <input type="number" name="duvet_single_in" class="form-control form-control-sm" min="0" value="<%= kamar.duvet_single_in %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Duvet Single OUT</label>
              <input type="number" name="duvet_single_out" class="form-control form-control-sm" min="0" value="<%= kamar.duvet_single_out %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Bath Towel IN</label>
              <input type="number" name="bath_towel_in" class="form-control form-control-sm" min="0" value="<%= kamar.bath_towel_in %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Bath Towel OUT</label>
              <input type="number" name="bath_towel_out" class="form-control form-control-sm" min="0" value="<%= kamar.bath_towel_out %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Hand Towel IN</label>
              <input type="number" name="hand_towel_in" class="form-control form-control-sm" min="0" value="<%= kamar.hand_towel_in %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Hand Towel OUT</label>
              <input type="number" name="hand_towel_out" class="form-control form-control-sm" min="0" value="<%= kamar.hand_towel_out %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Bath Mat IN</label>
              <input type="number" name="bath_mat_in" class="form-control form-control-sm" min="0" value="<%= kamar.bath_mat_in %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Bath Mat OUT</label>
              <input type="number" name="bath_mat_out" class="form-control form-control-sm" min="0" value="<%= kamar.bath_mat_out %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Pillow Case IN</label>
              <input type="number" name="pillow_case_in" class="form-control form-control-sm" min="0" value="<%= kamar.pillow_case_in %>">
            </div>
            <div class="col-md-3">
              <label class="form-label">Pillow Case OUT</label>
              <input type="number" name="pillow_case_out" class="form-control form-control-sm" min="0" value="<%= kamar.pillow_case_out %>">
            </div>
          </div>

          <!-- BATH ROOM -->
          <h6 class="section-title mt-4">BATH ROOM</h6>
          <div class="row g-3">
            <div class="col-md-2">
              <label class="form-label">Hand Soap</label>
              <input type="number" name="hand_soap" class="form-control form-control-sm" min="0" value="<%= kamar.hand_soap %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Shampoo</label>
              <input type="number" name="shampoo" class="form-control form-control-sm" min="0" value="<%= kamar.shampoo %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Shower Gel</label>
              <input type="number" name="shower_gel" class="form-control form-control-sm" min="0" value="<%= kamar.shower_gel %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Tooth Brush</label>
              <input type="number" name="tooth_brush" class="form-control form-control-sm" min="0" value="<%= kamar.tooth_brush %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Sterer</label>
              <input type="number" name="sterer" class="form-control form-control-sm" min="0" value="<%= kamar.sterer %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Shower Cap</label>
              <input type="number" name="shower_cap" class="form-control form-control-sm" min="0" value="<%= kamar.shower_cap %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Slipper</label>
              <input type="number" name="slipper" class="form-control form-control-sm" min="0" value="<%= kamar.slipper %>">
            </div>
          </div>

          <!-- BED ROOM -->
          <h6 class="section-title mt-4">BED ROOM</h6>
          <div class="row g-3">
            <div class="col-md-2">
              <label class="form-label">Laundry Bag</label>
              <input type="number" name="laundry_bag" class="form-control form-control-sm" min="0" value="<%= kamar.laundry_bag %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Laundry List</label>
              <input type="number" name="laundry_list" class="form-control form-control-sm" min="0" value="<%= kamar.laundry_list %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Memo Pad</label>
              <input type="number" name="memo_pad" class="form-control form-control-sm" min="0" value="<%= kamar.memo_pad %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Pencil</label>
              <input type="number" name="pencil" class="form-control form-control-sm" min="0" value="<%= kamar.pencil %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Plastic Bin</label>
              <input type="number" name="plastic_bin" class="form-control form-control-sm" min="0" value="<%= kamar.plastic_bin %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Tissue</label>
              <input type="number" name="tissue" class="form-control form-control-sm" min="0" value="<%= kamar.tissue %>">
            </div>
          </div>

          <!-- CONDIMEN -->
          <h6 class="section-title mt-4">CONDIMEN</h6>
          <div class="row g-3">
            <div class="col-md-2">
              <label class="form-label">Coffee</label>
              <input type="number" name="coffee" class="form-control form-control-sm" min="0" value="<%= kamar.coffee %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Sugar</label>
              <input type="number" name="sugar" class="form-control form-control-sm" min="0" value="<%= kamar.sugar %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Tea</label>
              <input type="number" name="tea" class="form-control form-control-sm" min="0" value="<%= kamar.tea %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Creamer</label>
              <input type="number" name="creamer" class="form-control form-control-sm" min="0" value="<%= kamar.creamer %>">
            </div>
            <div class="col-md-2">
              <label class="form-label">Mineral Water</label>
              <input type="number" name="mineral" class="form-control form-control-sm" min="0" value="<%= kamar.mineral %>">
            </div>
          </div>

          <div class="mt-4 text-end">
            <button type="submit" class="btn btn-success">
              <i class="bi bi-check-circle me-1"></i>Selesai & Simpan Laporan
            </button>
          </div>
        </form>
      </div>
      <% } else if (kamar.waktu_keluar !== '-') { %>
      <div class="card-body text-center text-success py-3">
        <i class="bi bi-check-circle-fill fs-1 mb-2"></i>
        <p class="mb-0">Laporan kebersihan sudah disimpan.</p>
        <small>Jam selesai: <%= kamar.waktu_keluar %></small>
      </div>
      <% } %>
    </div>
    <% }) %>
  <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
